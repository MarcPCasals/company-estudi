rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signedInWithGoogle() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function signedInWithPassword() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    function studentAccessExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/studentAccess/$(request.auth.uid));
    }

    function studentAccessData() {
      return get(
        /databases/$(database)/documents/studentAccess/$(request.auth.uid)
      ).data;
    }

    function isTutor(classId) {
      return signedInWithGoogle()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && get(/databases/$(database)/documents/classes/$(classId)).data.tutorId
          == request.auth.uid;
    }

    function isTutorAfter(classId) {
      return signedInWithGoogle()
        && getAfter(
          /databases/$(database)/documents/classes/$(classId)
        ).data.tutorId == request.auth.uid;
    }

    function hasCurrentStudentAccess(classId, studentId) {
      return signedInWithPassword()
        && studentAccessExists()
        && studentAccessData().active == true
        && studentAccessData().classId == classId
        && studentAccessData().studentId == studentId
        && exists(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        )
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.active == true
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.authUid == request.auth.uid
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.credentialVersion == studentAccessData().credentialVersion;
    }

    function isClassStudent(classId) {
      return studentAccessExists()
        && hasCurrentStudentAccess(classId, studentAccessData().studentId);
    }

    function ownsIncomingStudentData(classId, studentId) {
      return request.resource.data.classId == classId
        && request.resource.data.ownerStudentId == studentId;
    }

    function keepsStudentOwnership(classId, studentId) {
      return ownsIncomingStudentData(classId, studentId)
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.ownerStudentId == resource.data.ownerStudentId;
    }

    match /classes/{classId} {
      allow create: if signedInWithGoogle()
        && request.resource.data.tutorId == request.auth.uid;
      allow read: if (
          signedInWithGoogle()
          && resource.data.tutorId == request.auth.uid
        ) || isClassStudent(classId);
      allow update: if isTutor(classId)
        && request.resource.data.tutorId == resource.data.tutorId;
      allow delete: if isTutor(classId);

      match /students/{studentId} {
        allow read: if isTutor(classId)
          || hasCurrentStudentAccess(classId, studentId);
        allow create, update, delete: if isTutor(classId);

        match /private/{document=**} {
          allow read, write: if hasCurrentStudentAccess(classId, studentId);
        }

        match /tasks/{taskId} {
          allow read: if isTutor(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);

          match /history/{historyId} {
            allow read: if isTutor(classId)
              || hasCurrentStudentAccess(classId, studentId);
            allow create: if hasCurrentStudentAccess(classId, studentId)
              && request.resource.data.classId == classId
              && request.resource.data.ownerStudentId == studentId
              && request.resource.data.taskId == taskId
              && request.resource.data.actorRole == 'student'
              && request.resource.data.actorId == studentId;
            allow update, delete: if false;
          }
        }

        match /studySessions/{sessionId} {
          allow read: if isTutor(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /personalSchedule/{eventId} {
          allow read, write: if hasCurrentStudentAccess(classId, studentId);
        }

        match /availability/{summaryId} {
          allow read: if isTutor(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /tutorialSubmissions/{submissionId} {
          allow read: if isTutor(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /tutorFeedback/{feedbackId} {
          allow read: if isTutor(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if isTutor(classId)
            && request.resource.data.classId == classId
            && request.resource.data.studentId == studentId
            && request.resource.data.authorTutorId == request.auth.uid;
          allow update: if isTutor(classId)
            && resource.data.authorTutorId == request.auth.uid
            && request.resource.data.authorTutorId == resource.data.authorTutorId
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.studentId == resource.data.studentId;
          allow delete: if isTutor(classId)
            && resource.data.authorTutorId == request.auth.uid;
        }
      }

      match /subjects/{subjectId} {
        allow read: if isTutor(classId) || isClassStudent(classId);
        allow create: if isTutorAfter(classId);
        allow update, delete: if isTutor(classId);
      }

      match /rooms/{roomId} {
        allow read: if isTutor(classId) || isClassStudent(classId);
        allow create: if isTutorAfter(classId);
        allow update, delete: if isTutor(classId);

        match /posts/{postId} {
          allow read: if isTutor(classId) || isClassStudent(classId);
          allow create: if (
              isTutor(classId)
              && request.resource.data.authorRole == 'tutor'
              && request.resource.data.authorTutorId == request.auth.uid
            ) || (
              isClassStudent(classId)
              && request.resource.data.authorRole == 'student'
              && request.resource.data.authorStudentId == studentAccessData().studentId
            );
          allow update: if isTutor(classId) || (
            isClassStudent(classId)
            && resource.data.authorRole == 'student'
            && resource.data.authorStudentId == studentAccessData().studentId
            && request.resource.data.authorStudentId == resource.data.authorStudentId
            && request.resource.data.authorRole == resource.data.authorRole
          );
          allow delete: if isTutor(classId) || (
            isClassStudent(classId)
            && resource.data.authorRole == 'student'
            && resource.data.authorStudentId == studentAccessData().studentId
          );
        }

        match /reports/{reportId} {
          allow create: if isClassStudent(classId)
            && request.resource.data.reporterStudentId == studentAccessData().studentId;
          allow read, update, delete: if isTutor(classId);
        }
      }

      match /taskCandidates/{candidateId} {
        allow read: if isTutor(classId);
        allow write: if false;
      }

      match /aggregates/{aggregateId} {
        allow read: if isTutor(classId);
        allow write: if false;
      }
    }

    match /studentAccess/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid || isTutor(resource.data.classId)
      );
      allow create: if signedInWithGoogle()
        && isTutor(request.resource.data.classId)
        && request.resource.data.studentId == uid;
      allow update: if signedInWithGoogle()
        && isTutor(resource.data.classId)
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.studentId == resource.data.studentId;
      allow delete: if signedInWithGoogle() && isTutor(resource.data.classId);
    }

    match /tutors/{tutorId}/classSecrets/{classId} {
      allow read: if signedInWithGoogle() && request.auth.uid == tutorId;
      allow create: if signedInWithGoogle()
        && request.auth.uid == tutorId
        && isTutorAfter(classId);
      allow update, delete: if signedInWithGoogle()
        && request.auth.uid == tutorId
        && isTutor(classId);

      match /students/{studentId} {
        allow read, create, update, delete: if signedInWithGoogle()
          && request.auth.uid == tutorId
          && isTutor(classId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
