rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signedInWithGoogle() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function signedInWithPassword() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == 'password';
    }

    function studentAccessExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/studentAccess/$(request.auth.uid));
    }

    function studentAccessData() {
      return get(
        /databases/$(database)/documents/studentAccess/$(request.auth.uid)
      ).data;
    }

    function isOwner(classId) {
      return signedInWithGoogle()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && get(/databases/$(database)/documents/classes/$(classId)).data.tutorId
          == request.auth.uid;
    }

    function isOwnerAfter(classId) {
      return signedInWithGoogle()
        && getAfter(
          /databases/$(database)/documents/classes/$(classId)
        ).data.tutorId == request.auth.uid;
    }

    function isClassTeacher(classId) {
      return signedInWithGoogle()
        && exists(/databases/$(database)/documents/classes/$(classId))
        && (
          get(/databases/$(database)/documents/classes/$(classId)).data.tutorId
            == request.auth.uid
          || (
            get(/databases/$(database)/documents/classes/$(classId)).data.teacherIds is list
            && request.auth.uid in get(
              /databases/$(database)/documents/classes/$(classId)
            ).data.teacherIds
          )
        );
    }

    function keepsClassMembership() {
      return request.resource.data.tutorId == resource.data.tutorId
        && request.resource.data.teacherIds == resource.data.teacherIds
        && request.resource.data.get('cotutorId', null) == resource.data.get('cotutorId', null);
    }

    function acceptsValidCotutorInvitation(classId) {
      return signedInWithGoogle()
        && !(request.auth.uid in resource.data.teacherIds)
        && request.auth.uid in request.resource.data.teacherIds
        && request.resource.data.teacherIds.size() == resource.data.teacherIds.size() + 1
        && request.resource.data.tutorId == resource.data.tutorId
        && request.resource.data.cotutorId == request.auth.uid
        && request.resource.data.membershipInvitationId is string
        && getAfter(
          /databases/$(database)/documents/cotutorInvitations/$(request.resource.data.membershipInvitationId)
        ).data.classId == classId
        && getAfter(
          /databases/$(database)/documents/cotutorInvitations/$(request.resource.data.membershipInvitationId)
        ).data.status == 'accepted'
        && getAfter(
          /databases/$(database)/documents/cotutorInvitations/$(request.resource.data.membershipInvitationId)
        ).data.respondedByUid == request.auth.uid;
    }

    function leavesOwnCotutoria() {
      return signedInWithGoogle()
        && resource.data.cotutorId == request.auth.uid
        && !(request.auth.uid in request.resource.data.teacherIds)
        && request.resource.data.teacherIds.size() == resource.data.teacherIds.size() - 1
        && request.resource.data.tutorId == resource.data.tutorId
        && request.resource.data.cotutorId == null;
    }

    function ownerManagesMembership(classId) {
      return isOwner(classId) && (
        keepsClassMembership()
        || (
          request.resource.data.tutorId == resource.data.tutorId
          && request.resource.data.teacherIds.size() < resource.data.teacherIds.size()
          && request.resource.data.cotutorId == null
        )
        || (
          resource.data.cotutorId is string
          && request.resource.data.tutorId == resource.data.cotutorId
          && request.resource.data.cotutorId == request.auth.uid
          && request.resource.data.teacherIds == resource.data.teacherIds
        )
      );
    }

    function hasCurrentStudentAccess(classId, studentId) {
      return signedInWithPassword()
        && studentAccessExists()
        && studentAccessData().active == true
        && studentAccessData().classId == classId
        && studentAccessData().studentId == studentId
        && exists(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        )
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.active == true
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.authUid == request.auth.uid
        && get(
          /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
        ).data.credentialVersion == studentAccessData().credentialVersion;
    }

    function isClassStudent(classId) {
      return studentAccessExists()
        && hasCurrentStudentAccess(classId, studentAccessData().studentId);
    }

    function hasRoomAccess(classId, roomId) {
      return isClassStudent(classId)
        && exists(
          /databases/$(database)/documents/classes/$(classId)/rooms/$(roomId)
        )
        && (
          get(
            /databases/$(database)/documents/classes/$(classId)/rooms/$(roomId)
          ).data.memberMode != 'selected'
          || studentAccessData().studentId in get(
            /databases/$(database)/documents/classes/$(classId)/rooms/$(roomId)
          ).data.memberStudentIds
        );
    }

    function ownsIncomingStudentData(classId, studentId) {
      return request.resource.data.classId == classId
        && request.resource.data.ownerStudentId == studentId;
    }

    function keepsStudentOwnership(classId, studentId) {
      return ownsIncomingStudentData(classId, studentId)
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.ownerStudentId == resource.data.ownerStudentId;
    }

    function hasSafeTaskFields() {
      return request.resource.data.keys().hasOnly([
        'classId', 'ownerStudentId', 'subjectId', 'title', 'deadline',
        'recordKind', 'officialTaskId', 'taskType', 'estimatedMinutes',
        'steps', 'material', 'helpRequested', 'requiresDelivery', 'status',
        'deliveryStatus', 'progressPercent', 'fingerprint', 'activeSessionId',
        'nextPlannedSessionAt', 'plannedDurationMinutes', 'createdAt', 'updatedAt'
      ]);
    }

    function hasValidGamificationActionAndXp() {
      return (request.resource.data.action == 'planned' && request.resource.data.xp == 10)
        || (request.resource.data.action == 'divided' && request.resource.data.xp == 10)
        || (request.resource.data.action == 'early_start' && request.resource.data.xp == 12)
        || (request.resource.data.action == 'readjusted' && request.resource.data.xp == 8)
        || (request.resource.data.action == 'help_requested' && request.resource.data.xp == 8)
        || (request.resource.data.action == 'weekly_review' && request.resource.data.xp == 12);
    }

    match /classes/{classId} {
      allow create: if signedInWithGoogle()
        && request.resource.data.tutorId == request.auth.uid
        && request.resource.data.teacherIds == [request.auth.uid];
      allow read: if isClassTeacher(classId) || isClassStudent(classId);
      allow update: if acceptsValidCotutorInvitation(classId)
          || leavesOwnCotutoria()
          || ownerManagesMembership(classId);
      allow delete: if isOwner(classId);

      match /teacherMembers/{teacherId} {
        allow read: if isClassTeacher(classId);
        allow create: if teacherId == request.auth.uid
          && signedInWithGoogle()
          && getAfter(/databases/$(database)/documents/classes/$(classId)).data.teacherIds
            .hasAny([request.auth.uid]);
        allow update: if isOwner(classId) || (
          teacherId == request.auth.uid
          && signedInWithGoogle()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'leftAt'])
          && request.resource.data.status == 'left'
        );
        allow delete: if false;
      }

      match /studyRoomLeaderboard/{studentId} {
        allow get: if isClassTeacher(classId) || hasCurrentStudentAccess(classId, studentId);
        allow list: if isClassTeacher(classId);
        allow create, update: if isClassTeacher(classId) || (
          hasCurrentStudentAccess(classId, studentId)
          && request.resource.data.keys().hasOnly(['studentId', 'displayName', 'totalXp', 'updatedAt'])
          && request.resource.data.studentId == studentId
          && request.resource.data.displayName == get(
            /databases/$(database)/documents/classes/$(classId)/students/$(studentId)
          ).data.displayName
          && request.resource.data.totalXp >= 0
          && (
            (!exists(
              /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomProgress/current
            ) && request.resource.data.totalXp == 0)
            || getAfter(
              /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomProgress/current
            ).data.totalXp == request.resource.data.totalXp
          )
          && request.resource.data.updatedAt == request.time
        );
        allow delete: if isClassTeacher(classId);
      }

      match /studyRoomPodium/{podiumId} {
        allow read: if podiumId == 'current' && (isClassTeacher(classId) || isClassStudent(classId));
        allow create, update: if podiumId == 'current' && isClassTeacher(classId);
        allow delete: if false;
      }

      match /students/{studentId} {
        allow read: if isClassTeacher(classId)
          || hasCurrentStudentAccess(classId, studentId);
        allow create, update, delete: if isOwner(classId);

        match /private/{document=**} {
          allow read, write: if hasCurrentStudentAccess(classId, studentId);
        }

        match /private/studyRoomRanking {
          allow read, create, update: if isClassTeacher(classId);
          allow delete: if false;
        }

        match /tasks/{taskId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId)
            && hasSafeTaskFields();
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId)
            && hasSafeTaskFields();
          allow delete: if hasCurrentStudentAccess(classId, studentId);

          match /private/{privateDocumentId} {
            allow read, delete: if hasCurrentStudentAccess(classId, studentId);
            allow create, update: if hasCurrentStudentAccess(classId, studentId)
              && request.resource.data.keys().hasOnly(['privateNote', 'updatedAt']);
          }

          match /history/{historyId} {
            allow read: if isClassTeacher(classId)
              || hasCurrentStudentAccess(classId, studentId);
            allow create: if hasCurrentStudentAccess(classId, studentId)
              && request.resource.data.classId == classId
              && request.resource.data.ownerStudentId == studentId
              && request.resource.data.taskId == taskId
              && request.resource.data.actorRole == 'student'
              && request.resource.data.actorId == studentId;
            allow update, delete: if false;
          }
        }

        match /studySessions/{sessionId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /personalSchedule/{eventId} {
          allow read, write: if hasCurrentStudentAccess(classId, studentId);
        }

        match /availability/{summaryId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /tutorialSubmissions/{submissionId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && ownsIncomingStudentData(classId, studentId);
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && keepsStudentOwnership(classId, studentId);
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /privateQuestions/{questionId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.status == 'open';
          allow update: if isClassTeacher(classId)
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.ownerStudentId == resource.data.ownerStudentId;
          allow delete: if hasCurrentStudentAccess(classId, studentId)
            || isClassTeacher(classId);
        }

        match /tutorialGoals/{goalId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create, update: if isClassTeacher(classId)
            && request.resource.data.classId == classId
            && request.resource.data.studentId == studentId
            && request.resource.data.authorTutorId == request.auth.uid;
          allow delete: if isClassTeacher(classId);
        }

        match /sessionSuggestions/{suggestionId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if isClassTeacher(classId)
            && request.resource.data.classId == classId
            && request.resource.data.studentId == studentId
            && request.resource.data.authorTutorId == request.auth.uid
            && request.resource.data.status == 'pending';
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'respondedAt'])
            && request.resource.data.status in ['accepted', 'declined'];
          allow delete: if isClassTeacher(classId);
        }

        match /notices/{noticeId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if isClassTeacher(classId)
            && request.resource.data.classId == classId
            && request.resource.data.studentId == studentId
            && request.resource.data.authorTutorId == request.auth.uid;
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
          allow delete: if isClassTeacher(classId);
        }

        match /tutorFeedback/{feedbackId} {
          allow read: if isClassTeacher(classId)
            || hasCurrentStudentAccess(classId, studentId);
          allow create: if isClassTeacher(classId)
            && request.resource.data.classId == classId
            && request.resource.data.studentId == studentId
            && request.resource.data.authorTutorId == request.auth.uid;
          allow update: if isClassTeacher(classId)
            && resource.data.authorTutorId == request.auth.uid
            && request.resource.data.authorTutorId == resource.data.authorTutorId
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.studentId == resource.data.studentId;
          allow delete: if isClassTeacher(classId)
            && resource.data.authorTutorId == request.auth.uid;
        }

        match /gamificationEvents/{eventId} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.keys().hasOnly([
              'classId', 'ownerStudentId', 'action', 'sourceId',
              'weekKey', 'xp', 'createdAt'
            ])
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.sourceId is string
            && request.resource.data.weekKey is string
            && hasValidGamificationActionAndXp();
          allow update, delete: if false;
        }

        match /gamification/{preferenceId} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create, update: if hasCurrentStudentAccess(classId, studentId)
            && preferenceId == 'preferences'
            && request.resource.data.keys().hasOnly([
              'mode', 'animationsEnabled', 'accessory', 'updatedAt'
            ])
            && request.resource.data.mode in ['full', 'reduced', 'off']
            && request.resource.data.animationsEnabled is bool
            && request.resource.data.accessory is string;
          allow delete: if hasCurrentStudentAccess(classId, studentId);
        }

        match /studyRoomDays/{dayKey} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.keys().hasOnly([
              'classId', 'ownerStudentId', 'dayKey', 'completedBlocks', 'completedSessions', 'xp', 'updatedAt'
            ])
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.dayKey == dayKey
            && request.resource.data.completedBlocks == 1
            && request.resource.data.completedSessions in [0, 1]
            && request.resource.data.xp in [0, 4];
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.keys().hasOnly([
              'classId', 'ownerStudentId', 'dayKey', 'completedBlocks', 'completedSessions', 'xp', 'updatedAt'
            ])
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.ownerStudentId == resource.data.ownerStudentId
            && request.resource.data.dayKey == resource.data.dayKey
            && request.resource.data.completedBlocks == resource.data.completedBlocks + 1
            && request.resource.data.completedSessions in [resource.data.completedSessions, resource.data.completedSessions + 1]
            && request.resource.data.xp in [resource.data.xp, resource.data.xp + 4, resource.data.xp + 16]
            && request.resource.data.xp <= 40;
          allow delete: if false;
        }

        // Estat tècnic privat per reprendre el cronòmetre. El tutor no hi té accés.
        match /studyRoomActive/{activeId} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && activeId == 'current'
            && request.resource.data.keys().hasOnly([
              'version', 'classId', 'ownerStudentId', 'sessionId', 'status',
              'phase', 'phaseStep', 'focusMinutes', 'focusLabel', 'completedBlocks',
              'startedAt', 'timer', 'updatedAt'
            ])
            && request.resource.data.version == 1
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.sessionId is string
            && request.resource.data.status == 'active'
            && request.resource.data.phase in ['preparation', 'focus_one', 'review_one', 'break', 'focus_two', 'review_two']
            && request.resource.data.phaseStep in [0, 1, 2, 3, 4, 5]
            && request.resource.data.focusMinutes in [25, 30, 45]
            && request.resource.data.focusLabel is string
            && request.resource.data.completedBlocks in [0, 1, 2]
            && request.resource.data.startedAt is number;
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && activeId == 'current'
            && request.resource.data.keys().hasOnly([
              'version', 'classId', 'ownerStudentId', 'sessionId', 'status',
              'phase', 'phaseStep', 'focusMinutes', 'focusLabel', 'completedBlocks',
              'startedAt', 'timer', 'updatedAt'
            ])
            && request.resource.data.version == 1
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.ownerStudentId == resource.data.ownerStudentId
            && request.resource.data.status in ['active', 'completed', 'abandoned']
            && request.resource.data.phase in ['preparation', 'focus_one', 'review_one', 'break', 'focus_two', 'review_two']
            && request.resource.data.phaseStep in [0, 1, 2, 3, 4, 5]
            && request.resource.data.focusMinutes in [25, 30, 45]
            && request.resource.data.focusLabel is string
            && request.resource.data.completedBlocks in [0, 1, 2]
            && request.resource.data.startedAt is number
            && (resource.data.status != 'active' || (
              request.resource.data.sessionId == resource.data.sessionId
              && request.resource.data.phaseStep >= resource.data.phaseStep
            ));
          allow delete: if false;
        }

        match /studyRoomProgress/{progressId} {
          allow read: if hasCurrentStudentAccess(classId, studentId) || isClassTeacher(classId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && progressId == 'current'
            && request.resource.data.keys().hasOnly(['classId', 'ownerStudentId', 'totalXp', 'rewardedBlocks', 'updatedAt'])
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.totalXp in [4, 16]
            && request.resource.data.rewardedBlocks == 1;
          allow update: if hasCurrentStudentAccess(classId, studentId)
            && progressId == 'current'
            && request.resource.data.keys().hasOnly(['classId', 'ownerStudentId', 'totalXp', 'rewardedBlocks', 'updatedAt'])
            && request.resource.data.classId == resource.data.classId
            && request.resource.data.ownerStudentId == resource.data.ownerStudentId
            && request.resource.data.totalXp in [resource.data.totalXp + 4, resource.data.totalXp + 16]
            && request.resource.data.rewardedBlocks == resource.data.rewardedBlocks + 1;
          allow delete: if false;
        }

        match /studyRoomBlocks/{blockId} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.keys().hasOnly([
              'classId', 'ownerStudentId', 'sessionId', 'blockNumber', 'dayKey',
              'durationMinutes', 'reflection', 'xp', 'dailyXpAfter',
              'reason', 'createdAt'
            ])
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.sessionId is string
            && request.resource.data.blockNumber in [1, 2]
            && request.resource.data.durationMinutes in [25, 30, 45]
            && request.resource.data.reflection is string
            && request.resource.data.xp in [0, 4, 16]
            && request.resource.data.dailyXpAfter >= 0
            && request.resource.data.dailyXpAfter <= 40
            && request.resource.data.reason in ['awarded_block', 'awarded_full_session', 'daily_limit']
            && get(
              /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomActive/current
            ).data.status == 'active'
            && get(
              /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomActive/current
            ).data.sessionId == request.resource.data.sessionId
            && (
              getAfter(
                  /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomDays/$(request.resource.data.dayKey)
                ).data.xp == request.resource.data.dailyXpAfter
              && getAfter(
                  /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomDays/$(request.resource.data.dayKey)
                ).data.updatedAt == request.time
              && (
                request.resource.data.xp == 0
                || getAfter(
                  /databases/$(database)/documents/classes/$(classId)/students/$(studentId)/studyRoomProgress/current
                ).data.updatedAt == request.time
              )
            );
          allow update, delete: if false;
        }

        match /missionContributions/{missionId} {
          allow read: if hasCurrentStudentAccess(classId, studentId);
          allow create: if hasCurrentStudentAccess(classId, studentId)
            && request.resource.data.keys().hasOnly([
              'classId', 'ownerStudentId', 'missionId', 'weekKey', 'contributedAt'
            ])
            && request.resource.data.classId == classId
            && request.resource.data.ownerStudentId == studentId
            && request.resource.data.missionId == missionId
            && getAfter(
              /databases/$(database)/documents/classes/$(classId)/cooperativeMissions/$(missionId)
            ).data.progress == get(
              /databases/$(database)/documents/classes/$(classId)/cooperativeMissions/$(missionId)
            ).data.progress + 1;
          allow update, delete: if false;
        }
      }

      match /subjects/{subjectId} {
        allow read: if isClassTeacher(classId) || isClassStudent(classId);
        allow create: if isOwnerAfter(classId);
        allow update, delete: if isOwner(classId);
      }

      match /rooms/{roomId} {
        allow read: if isClassTeacher(classId) || hasRoomAccess(classId, roomId);
        allow create: if isOwnerAfter(classId);
        allow update, delete: if isOwner(classId);

        match /posts/{postId} {
          allow read: if isClassTeacher(classId) || hasRoomAccess(classId, roomId);
          allow create: if (
              isClassTeacher(classId)
              && request.resource.data.authorRole == 'tutor'
              && request.resource.data.authorTutorId == request.auth.uid
              && request.resource.data.authorName is string
            ) || (
              hasRoomAccess(classId, roomId)
              && request.resource.data.authorRole == 'student'
              && request.resource.data.authorStudentId == studentAccessData().studentId
              && request.resource.data.authorName is string
              && request.resource.data.type != 'notice'
            );
          allow update: if isClassTeacher(classId) || (
            hasRoomAccess(classId, roomId)
            && resource.data.authorRole == 'student'
            && resource.data.authorStudentId == studentAccessData().studentId
            && request.resource.data.authorStudentId == resource.data.authorStudentId
            && request.resource.data.authorRole == resource.data.authorRole
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['body', 'resolved', 'updatedAt'])
          );
          allow delete: if isClassTeacher(classId) || (
            hasRoomAccess(classId, roomId)
            && resource.data.authorRole == 'student'
            && resource.data.authorStudentId == studentAccessData().studentId
          );

          match /usefulMarks/{studentId} {
            allow read: if isClassTeacher(classId) || hasRoomAccess(classId, roomId);
            allow create: if hasRoomAccess(classId, roomId)
              && studentId == studentAccessData().studentId
              && request.resource.data.studentId == studentId;
            allow delete: if hasRoomAccess(classId, roomId)
              && studentId == studentAccessData().studentId;
            allow update: if false;
          }
        }

        match /reports/{reportId} {
          allow create: if hasRoomAccess(classId, roomId)
            && request.resource.data.reporterStudentId == studentAccessData().studentId;
          allow read, update, delete: if isClassTeacher(classId);
        }
      }

      match /taskCandidates/{candidateId} {
        allow read: if isClassTeacher(classId);
        allow create, update: if isClassTeacher(classId)
          && request.resource.data.classId == classId
          && request.resource.data.reviewedByTutorId == request.auth.uid;
        allow delete: if isClassTeacher(classId);
      }

      match /officialTasks/{officialTaskId} {
        allow read: if isClassTeacher(classId) || isClassStudent(classId);
        allow create, update: if isClassTeacher(classId)
          && request.resource.data.classId == classId
          && request.resource.data.confirmedByTutorId == request.auth.uid;
        allow delete: if isClassTeacher(classId);
      }

      match /taskAlerts/{alertId} {
        allow read: if isClassTeacher(classId) || isClassStudent(classId);
        allow create: if isClassTeacher(classId)
          && request.resource.data.classId == classId
          && request.resource.data.type == 'contradiction'
          && request.resource.data.status == 'active'
          && request.resource.data.publishedByTutorId == request.auth.uid;
        allow update: if isClassTeacher(classId)
          && request.resource.data.classId == resource.data.classId
          && request.resource.data.publishedByTutorId == resource.data.publishedByTutorId
          && request.resource.data.status in ['active', 'resolved'];
        allow delete: if isClassTeacher(classId);
      }

      match /aggregates/{aggregateId} {
        allow read: if isClassTeacher(classId);
        allow write: if false;
      }

      match /cooperativeMissions/{missionId} {
        allow read: if isClassTeacher(classId) || isClassStudent(classId);
        allow create: if isClassTeacher(classId)
          && request.resource.data.keys().hasOnly([
            'classId', 'title', 'description', 'action', 'target', 'progress',
            'weekKey', 'status', 'createdByTutorId', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.classId == classId
          && request.resource.data.createdByTutorId == request.auth.uid
          && request.resource.data.progress == 0
          && request.resource.data.status == 'active';
        allow update: if isClassTeacher(classId) || (
          isClassStudent(classId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['progress', 'status', 'updatedAt'])
          && request.resource.data.progress == resource.data.progress + 1
          && request.resource.data.progress <= resource.data.target
          && (
            (request.resource.data.progress < resource.data.target
              && request.resource.data.status == 'active')
            || (request.resource.data.progress == resource.data.target
              && request.resource.data.status == 'completed')
          )
          && !exists(
            /databases/$(database)/documents/classes/$(classId)/students/$(studentAccessData().studentId)/missionContributions/$(missionId)
          )
          && getAfter(
            /databases/$(database)/documents/classes/$(classId)/students/$(studentAccessData().studentId)/missionContributions/$(missionId)
          ).data.ownerStudentId == studentAccessData().studentId
        );
        allow delete: if isClassTeacher(classId);
      }
    }

    match /cotutorInvitations/{invitationId} {
      allow create: if signedInWithGoogle()
        && request.resource.data.keys().hasOnly([
          'classId', 'className', 'classCourse', 'ownerTutorId',
          'ownerDisplayName', 'inviteeEmailNormalized', 'status',
          'createdAt', 'expiresAt'
        ])
        && request.resource.data.ownerTutorId == request.auth.uid
        && isOwner(request.resource.data.classId)
        && request.resource.data.status == 'pending'
        && request.resource.data.inviteeEmailNormalized is string
        && request.resource.data.inviteeEmailNormalized != request.auth.token.email;
      allow read: if signedInWithGoogle() && (
        resource.data.ownerTutorId == request.auth.uid
        || resource.data.inviteeEmailNormalized == request.auth.token.email
      );
      allow update: if signedInWithGoogle() && (
        (
          resource.data.ownerTutorId == request.auth.uid
          && isOwner(resource.data.classId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'revokedAt'])
          && request.resource.data.status == 'revoked'
        ) || (
          resource.data.inviteeEmailNormalized == request.auth.token.email
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'respondedAt', 'respondedByUid'])
          && resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'rejected']
          && request.resource.data.respondedByUid == request.auth.uid
          && request.time < resource.data.expiresAt
        )
      );
      allow delete: if false;
    }

    match /studentAccess/{uid} {
      allow read: if signedIn() && (
        request.auth.uid == uid || isOwner(resource.data.classId)
      );
      allow create: if signedInWithGoogle()
        && isOwner(request.resource.data.classId)
        && getAfter(
          /databases/$(database)/documents/classes/$(request.resource.data.classId)/students/$(request.resource.data.studentId)
        ).data.authUid == uid;
      allow update: if signedInWithGoogle()
        && isOwner(resource.data.classId)
        && request.resource.data.classId == resource.data.classId
        && request.resource.data.studentId == resource.data.studentId;
      allow delete: if signedInWithGoogle() && isOwner(resource.data.classId);
    }

    match /tutors/{tutorId}/classSecrets/{classId} {
      allow read: if signedInWithGoogle()
        && request.auth.uid == tutorId
        && isOwner(classId);
      allow create: if signedInWithGoogle() && (
          request.auth.uid == tutorId
          || isOwner(classId)
        ) && getAfter(
          /databases/$(database)/documents/classes/$(classId)
        ).data.tutorId == tutorId;
      allow update, delete: if signedInWithGoogle()
        && request.auth.uid == tutorId
        && isOwner(classId);

      match /students/{studentId} {
        allow read, create, update, delete: if signedInWithGoogle()
          && request.auth.uid == tutorId
          && isOwner(classId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
